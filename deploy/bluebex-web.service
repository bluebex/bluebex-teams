[Unit]
Description=Bluebex Teams Web (Next.js)
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/opt/bluebex-teams/apps/web
EnvironmentFile=/opt/bluebex-teams/.env
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=HOSTNAME=0.0.0.0
ExecStart=/usr/bin/npx next start -p 3000 -H 0.0.0.0
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
